# =============================================
# アズカル 環境変数テンプレート
# .env.local にコピーして値を入力してください
# =============================================

# ── Supabase ──────────────────────────────────
# Supabase Dashboard > Project Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Webhookのみで使用（公開しないこと）

# ── Stripe ────────────────────────────────────
# https://dashboard.stripe.com/apikeys から取得
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripeダッシュボード > Webhooks から取得
# エンドポイント: https://your-app.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── アプリ設定 ──────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
